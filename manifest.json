{
  "manifest_version": 3,
  "name": "SPID Certificate Validator",
  "version": "1.0.0",
  "description": "Validazione di certificati X.509 SPID compliant selezionati come testo.",
  "permissions": [
    "contextMenus",
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SPID Certificate Validator"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["results.html", "results.js", "styles/results.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
